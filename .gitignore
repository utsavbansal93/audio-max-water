.venv
.venv/
__pycache__/
*.pyc
.DS_Store
# In build* dirs: keep only script.json (the authored parse output).
# Everything else (per-line wavs, silence clips, concat.txt, chapter mp3s,
# ffmpeg metadata) is regenerable and gets ignored.
build*/ch*/
build*/**/*.wav
build*/**/*.mp3
build*/**/concat.txt
build*/**/_concat.txt
build*/**/_chapters.ffmeta
# UI-created build directories (per-session work scratchpads). Regenerable.
build/_ui_*/
build/_ui_uploads/
# Persistent job records (user-specific state, not code).
build/_jobs/
!build/.gitkeep

# setuptools metadata for editable installs — regenerated on every pip install -e .
*.egg-info/

# User-placed inputs that aren't part of the canonical example set.
# Keep the three tracked stories (*.md) by excluding only non-.md entries.
stories/*.epub
stories/*.pdf
stories/*.docx
stories/*.mobi
stories/*.txt
stories/*.epub/

out/**
!out/.gitkeep
samples/**
!samples/.gitkeep
voice_samples/**
!voice_samples/.gitkeep
!voice_samples/SOURCES.md
# Reference clips used by Chatterbox are tracked — they're small (8-10 s
# each, ~400 KB) and without them the repo can't reproduce the hybrid
# Gatsby sample. Sources documented in SOURCES.md.
!voice_samples/*.wav

# cast*.json is tracked authored configuration. A stray script.json at the
# repo root (not inside build*/) stays ignored as a safety net — the
# authored script files live at build*/script.json and have an explicit
# !build*/script.json override implied by the allow-list above.
/script.json

# Secrets — API keys, credentials. NEVER commit.
.env
.env.*
!.env.example
*.pem
*.key

.claude/
