.venv
.venv/
__pycache__/
*.pyc
.DS_Store
# In build* dirs: keep only script.json (the authored parse output).
# Everything else (per-line wavs, silence clips, concat.txt, chapter mp3s,
# ffmpeg metadata) is regenerable and gets ignored.
build*/ch*/
build*/**/*.wav
build*/**/*.mp3
build*/**/concat.txt
build*/**/_concat.txt
build*/**/_chapters.ffmeta
!build/.gitkeep

out/**
!out/.gitkeep
samples/**
!samples/.gitkeep
voice_samples/**
!voice_samples/.gitkeep
!voice_samples/SOURCES.md

# cast*.json is tracked authored configuration. A stray script.json at the
# repo root (not inside build*/) stays ignored as a safety net — the
# authored script files live at build*/script.json and have an explicit
# !build*/script.json override implied by the allow-list above.
/script.json

# Story-specific opt-outs (see commit history for rationale per path).
stories/salt-and-rust.md
