# Copy this file to `.env` and fill in whichever provider you use.
# `.env` is gitignored; `.env.example` is committed as a template.
# `pipeline.run` auto-loads `.env` from the repo root at startup.

# Anthropic (default provider)
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini (alternative provider; pass --provider gemini)
# GEMINI_API_KEY=...
